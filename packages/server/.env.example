# Server environment variables — copy to `.env` and fill in the keys you want to use.
# `.env` is gitignored; never commit real keys.
#
# LLM provider API keys for AI fixture creation (Library → ✨ AI).
# Keys are read server-side only; set whichever provider(s) you intend to use.
# Restart the server after editing so the values are loaded.

# Claude (Anthropic) — default model: claude-sonnet-4-6
ANTHROPIC_API_KEY=

# ChatGPT (OpenAI) — default model: gpt-4o
OPENAI_API_KEY=

# DeepSeek — default model: deepseek-chat
DEEPSEEK_API_KEY=
