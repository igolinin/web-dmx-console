    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "@types/xml2js": "^0.4.14",
    "tsx": "^4.15.1",
    "vitest": "^1.6.0"
  }
